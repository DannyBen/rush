#!/usr/bin/env bash

# === Private helpers ===

print_in_color() {
  local color="$1"
  shift
  if [[ -z ${NO_COLOR+x} ]]; then
    printf "$color%b\e[0m\n" "$*"
  else
    printf "%b\n" "$*"
  fi
}

red() { print_in_color "\e[31m" "$*"; }
green_bold() { print_in_color "\e[1;32m" "$*"; }
blue() { print_in_color "\e[34m" "$*"; }

section() {
  printf "\n=== %s\n" "$(green_bold "$@")"
}

command_exist() { [[ -x "$(command -v "$1")" ]]; }

onerror() {
  local exit_status=$?
  printf "\n=== %s\n" "$(red "Aborted with exit status $exit_status")"
  exit "$exit_status"
}

fail() {
  printf "$(red 'ERR') %s\n" "$*"
  return 1
}

warn() {
  printf "$(red 'WARN') %s\n" "$*"
}

is_writable_dir() {
  [[ -d "$1" && -w "$1" ]]
}

path_contains() {
  [[ ":$PATH:" == *":$1:"* ]]
}

sudo_usable() {
  command_exist sudo && sudo -n true >/dev/null 2>&1
}

resolve_install_targets() {
  prefix=''
  install_mode=''

  local user_bin="${HOME}/.local/bin"

  if is_writable_dir "/usr/local/bin" || [[ $EUID -eq 0 ]]; then
    prefix="/usr/local"
    install_mode="system"
    return 0
  fi

  if sudo_usable; then
    prefix="/usr/local"
    install_mode="system"
    return 0
  fi

  if is_writable_dir "$user_bin" && path_contains "$user_bin"; then
    prefix="${HOME}/.local"
    install_mode="user"
    return 0
  fi

  if is_writable_dir "$user_bin"; then
    fail "Cannot choose an install location automatically"
    printf "Reason: %s is writable, but not in PATH.\n" "$user_bin"
    printf "Fix:\n"
    printf '%s\n' "  export PATH=\"\$HOME/.local/bin:\$PATH\""
    printf "Then run setup again.\n"
    return 1
  fi

  fail "Cannot choose an install location automatically"
  printf "I could not use any of these options:\n"
  printf "  1) /usr/local/bin writable\n"
  printf "  2) sudo available for /usr/local/bin\n"
  printf "  3) ~/.local/bin writable and in PATH\n"
  printf "Possible fixes:\n"
  printf "  - enable sudo for this user, or\n"
  printf "  - create ~/.local/bin and add it to PATH:\n"
  printf '%s\n' "      mkdir -p \"\$HOME/.local/bin\""
  printf '%s\n' "      export PATH=\"\$HOME/.local/bin:\$PATH\""
  printf "Then run setup again.\n"
  return 1
}

command_prefix_for_target() {
  local target="$1"
  local dir="$target"

  [[ -d "$dir" ]] || dir="$(dirname "$target")"

  if [[ $EUID -eq 0 || -w "$dir" ]]; then
    printf ''
    return 0
  fi

  if sudo_usable; then
    printf 'sudo'
    return 0
  fi

  fail "Permission denied for $dir and sudo is unavailable"
  return 1
}

ensure_dir() {
  local dir="$1"
  [[ -d "$dir" ]] && return

  local cmd_prefix
  cmd_prefix="$(command_prefix_for_target "$dir")"

  if [[ -n "$cmd_prefix" ]]; then
    sudo mkdir -p "$dir"
  else
    mkdir -p "$dir"
  fi
}

completion_dir_for_mode() {
  if [[ "$install_mode" == "system" ]]; then
    if [[ -d "/usr/local/share/bash-completion/completions" ]]; then
      printf "/usr/local/share/bash-completion/completions"
      return
    fi
    if [[ -d "/usr/local/etc/bash_completion.d" ]]; then
      printf "/usr/local/etc/bash_completion.d"
      return
    fi
    if [[ -d "/usr/share/bash-completion/completions" ]]; then
      printf "/usr/share/bash-completion/completions"
      return
    fi
    if command_exist brew; then
      local brew_compdir
      brew_compdir="$(brew --prefix 2>/dev/null)/etc/bash_completion.d"
      if [[ -n "$brew_compdir" && -d "$brew_compdir" ]]; then
        printf "%s" "$brew_compdir"
        return
      fi
    fi
    printf ""
    return
  fi

  printf "%s/bash-completion/completions" "${XDG_DATA_HOME:-$HOME/.local/share}"
}

copy_file() {
  local source="$1"
  local dest_dir="$2"
  local mode="$3"
  local cmd_prefix

  printf "%s => %s\n" "$(blue "$(printf '%-25s' "$source")")" "$dest_dir"
  cmd_prefix="$(command_prefix_for_target "$dest_dir")"

  if [[ -n "$cmd_prefix" && -n "$mode" ]]; then
    sudo install -m "$mode" "$source" "$dest_dir"
  elif [[ -n "$cmd_prefix" ]]; then
    sudo install "$source" "$dest_dir"
  elif [[ -n "$mode" ]]; then
    install -m "$mode" "$source" "$dest_dir"
  else
    install "$source" "$dest_dir"
  fi
}

print_target_summary() {
  section "Install target"
  printf "mode: %s\n" "$install_mode"
  printf "prefix: %s\n" "$prefix"
  printf "bin: %s\n" "$prefix/bin"

  local compdir
  compdir="$(completion_dir_for_mode)"
  if [[ -n "$compdir" ]]; then
    printf "completions: %s\n" "$compdir"
  else
    printf "completions: (not found)\n"
  fi
}

# === Public DSL ===

need() {
  command_exist "$1" || fail "Cannot run $1"
  printf "%s found\n" "$(blue "    $1")"
}

initialize() {
  local repo="$1"

  set -e
  trap 'onerror' ERR

  resolve_install_targets
  print_target_summary

  repo_url="https://github.com/${repo}.git"
  pushd "$(mktemp -d)" >/dev/null
}

install_executable() {
  local source="${1:?missing source file}"
  local target_name="${2:-${source##*/}}"

  copy_file "$source" "$prefix/bin/$target_name" "755"
}

install_man() {
  local source_dir="${1:?missing man dir}"
  local glob="${2:-*.1}"

  [[ -d "$source_dir" ]] || return

  shopt -s nullglob
  # shellcheck disable=SC2206
  local files=("$source_dir"/$glob)
  shopt -u nullglob
  [[ ${#files[@]} -gt 0 ]] || return

  local file section_id man_dir
  for file in "${files[@]}"; do
    section_id="${file##*.}"
    if [[ "$install_mode" == "system" ]]; then
      man_dir="/usr/local/share/man/man${section_id}"
      ensure_dir "$man_dir"
    else
      man_dir="${XDG_DATA_HOME:-$HOME/.local/share}/man/man${section_id}"
      mkdir -p "$man_dir"
    fi

    copy_file "$file" "$man_dir/"
  done

  if [[ "$install_mode" == "system" ]] && command_exist makewhatis; then
    if [[ -n "$(command_prefix_for_target "/usr/local/man")" ]]; then
      sudo makewhatis /usr/local/man
    else
      makewhatis /usr/local/man
    fi
  fi
}

install_completions() {
  local cmd="${1:-}"
  local name="${2:-}"
  local compdir

  [[ -n "$cmd" && -n "$name" ]] || return

  compdir="$(completion_dir_for_mode)"
  if [[ -z "$compdir" ]]; then
    warn "skipping completions installation, compdir not found"
    printf "Install manually by adding this to your startup script:\n"
    printf "  %s\n" "$cmd"
    return
  fi

  if [[ "$install_mode" == "user" ]]; then
    mkdir -p "$compdir"
  fi

  local cmd_prefix
  cmd_prefix="$(command_prefix_for_target "$compdir/$name")"
  printf "copying to %s\n" "$compdir"
  if [[ -n "$cmd_prefix" ]]; then
    printf '%s\n' "$cmd" | sudo tee "${compdir}/${name}" >/dev/null
  else
    printf '%s\n' "$cmd" | tee "${compdir}/${name}" >/dev/null
  fi
}

# === Run ===

section "Initializing"
initialize "DannyBen/rush"

section "Checking for pre-requisites"
need git

section "Cloning DannyBen/rush"
git clone --depth 1 "$repo_url" .

section "Copying files"
install_executable "rush"
install_man "doc" "*.1"

section "Installing bash completions"
install_completions "eval \"\$(rush completions)\"" "rush"

section "Done"
rush --version
printf "%s\n" "Run rush --help to get started."
